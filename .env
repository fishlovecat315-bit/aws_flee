# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/nothing_aws_cost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
REDIS_URL=redis://redis:6379/0

# AWS Credentials (replace with your actual credentials)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# AWS Account IDs (replace with your actual account IDs)
PLM_ACCOUNT_ID=111111111111
MAIN_ACCOUNT_ID=222222222222
CN_ACCOUNT_ID=333333333333

# DingTalk Webhook (replace with your actual webhook URL)
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your-token

# CORS
CORS_ORIGINS=["http://localhost:3000"]
